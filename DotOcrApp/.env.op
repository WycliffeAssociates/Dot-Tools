# 1Password secret-reference file. Committed on purpose — these are op://
# references, NOT secret values. Resolved at launch by `op run` (see README):
#
#   op run --env-file=.env.op -- docker compose up
#
# Reference format: op://<vault>/<item>/<field>. Fill in the vault/item/field
# to match your 1Password vault. Non-secret config (bucket names, public URL)
# can stay as literal values.

# --- Brightcove ---
BRIGHTCOVE_ACCOUNT_ID=op://DevOps/Brightcove-ocr-api-credentials/bc-account-id
BRIGHTCOVE_CLIENT_ID=op://DevOps/Brightcove-ocr-api-credentials/client-id
BRIGHTCOVE_CLIENT_SECRET=op://DevOps/Brightcove-ocr-api-credentials/client-secret
BRIGHTCOVE_POLICY_KEY=op://DevOps/Brightcove-ocr-api-credentials/bc-policy-key

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=op://DevOps/cloudflare-r2-token/account-id
R2_ACCESS_KEY_ID=op://DevOps/cloudflare-r2-token/access-key-id
R2_SECRET_ACCESS_KEY=op://DevOps/cloudflare-r2-token/secret-access-key

# --- Non-secret config (literal values are fine) ---
R2_BUCKET_ASSETS=op://DevOps/Brightcove-ocr-api-credentials/r2-bucket-assets-name
R2_BUCKET_TMP=op://DevOps/Brightcove-ocr-api-credentials/r2-bucket-tmp
R2_PUBLIC_ASSETS_URL=op://DevOps/Brightcove-ocr-api-credentials/r2-dot-assets-public-url
